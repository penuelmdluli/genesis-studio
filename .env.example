# ============================================
# GENESIS STUDIO — Environment Variables
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Server-side URL for webhooks (MUST be set to production URL on Vercel)
APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME="Genesis Studio"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CREATOR_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_STUDIO_PRICE_ID=price_xxx
STRIPE_CREDIT_PACK_500_PRICE_ID=price_xxx
STRIPE_CREDIT_PACK_2000_PRICE_ID=price_xxx
STRIPE_CREDIT_PACK_10000_PRICE_ID=price_xxx

# RunPod
RUNPOD_API_KEY=rp_xxx
RUNPOD_WEBHOOK_SECRET=your-webhook-secret

# RunPod Serverless Endpoint IDs
RUNPOD_ENDPOINT_WAN22=wan-2-2-t2v-720
RUNPOD_ENDPOINT_WAN22_I2V=wan-2-2-i2v-720-lora
RUNPOD_ENDPOINT_HUNYUAN=your-endpoint-id
RUNPOD_ENDPOINT_LTX=your-endpoint-id
RUNPOD_ENDPOINT_WAN21_TURBO=your-endpoint-id
RUNPOD_ENDPOINT_MOCHI=your-endpoint-id
RUNPOD_ENDPOINT_COGVIDEO=your-endpoint-id
RUNPOD_ENDPOINT_MIMIC_MOTION=your-endpoint-id

# RunPod Hub Feature Endpoints
RUNPOD_ENDPOINT_CAPTIONS=your-endpoint-id
RUNPOD_ENDPOINT_TALKING_AVATAR=
RUNPOD_ENDPOINT_VOICEOVER=
RUNPOD_ENDPOINT_THUMBNAILS=
RUNPOD_ENDPOINT_UPSCALE=
RUNPOD_ENDPOINT_VIDEO_EFFECTS=
RUNPOD_ENDPOINT_FACE_SWAP=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=genesis-videos
R2_PUBLIC_URL=https://videos.genesisstudio.ai

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Claude API for prompt enhancement, moderation, and quality scoring
ANTHROPIC_API_KEY=sk-ant-xxx

# WhatsApp Notifications (WATI)
WATI_API_URL=https://live-mt-server.wati.io/XXXXX/api/v1
WATI_API_KEY=your-wati-api-key

# FAL.AI (FLUX Pro image generation + Hollywood video models)
FAL_KEY=your-fal-api-key

# PayFast (South African payments — EFT, SnapScan, Mobicred)
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=true

# EskomSePush (Load Shedding API)
ESKOMSEPUSH_API_KEY=your-esp-api-key

# Resend (Email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@genesis-studio.app

# Cron Jobs
CRON_SECRET=your-cron-secret

# Stripe Annual Plans
STRIPE_CREATOR_ANNUAL_PRICE_ID=price_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
STRIPE_STUDIO_ANNUAL_PRICE_ID=price_xxx

# Paystack (African payments)
PAYSTACK_SECRET_KEY=sk_test_xxx

# Yoco (South African card payments)
YOCO_SECRET_KEY=sk_test_xxx
YOCO_WEBHOOK_SECRET=whsec_xxx

# Stripe Tax (optional — set to "true" to enable automatic tax)
STRIPE_TAX_ENABLED=false

# Custom TTS endpoint (optional — falls back to Edge TTS)
# TTS_ENDPOINT_URL=https://your-tts-endpoint.com

# Replicate (optional — vendor failover)
# REPLICATE_API_KEY=r8_xxx

# Owner Account (bypass credits for testing)
OWNER_CLERK_IDS=user_xxx
